@page "{id:int}"
@model Web_Buoi4.Pages.EditTask.EditTaskModel

<h1>Sửa công việc</h1>

<form method="post">
    <div>
        <label>Mã công việc</label>
        <input asp-for="Task.Id" readonly />
    </div>

    <div>
        <label>Tên công việc</label>
        <input asp-for="Task.TaskName" />
    </div>

    <div>
        <input asp-for="Task.IsCompleted" />
        <label>Trạng thái hoàn thành</label>
    </div>

    <button type="submit">Sửa</button>
</form>

<a href="/TodoList">Quay trở lại</a>