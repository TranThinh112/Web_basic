
@model List<Web_Buoi_5.Models.Student>

<h1>Danh sách sinh viên</h1>

<a asp-action="Create">Thêm mới</a>

<table border="1">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Email</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.Email</td>
        </tr>
    }
</table>