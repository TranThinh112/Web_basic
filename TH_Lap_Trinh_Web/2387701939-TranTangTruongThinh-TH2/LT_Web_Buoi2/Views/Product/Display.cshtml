@model LT_Web_Buoi2.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<h2>Product Details</h2>

<div>
    <h4>Name: @Model.Name</h4>
    <h4>Price: @Model.Price</h4>
    <h4>Description: @Model.Description</h4>
    <h4>CategoryId: @Model.CategoryId</h4>
</div>

@if (!string.IsNullOrEmpty(Model.ImageUrl))
{
    <div class="mt-3">
        <h4>Image:</h4>
        <img src="@Model.ImageUrl" alt="Product Image" style="width: 300px; height: auto;" />
    </div>
}

@if (Model.ImageUrls != null && Model.ImageUrls.Count > 0)
{
    <div class="mt-3">
        <h4>Additional Images:</h4>

        @foreach (var imageUrl in Model.ImageUrls)
        {
            <img src="@imageUrl" alt="Product Image" style="width: 200px; height: auto; margin: 5px;" />
        }
    </div>
}

<br />

<a asp-action="Index">Back to List</a>