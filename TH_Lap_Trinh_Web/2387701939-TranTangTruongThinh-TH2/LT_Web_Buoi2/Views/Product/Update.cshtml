@model LT_Web_Buoi2.Models.Product

@{
    ViewData["Title"] = "Edit Product";
}

<h2>Edit Product</h2>

<form asp-action="Update" method="post"  enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    
    <input type="file" name="imageUrls" multiple class="form-control" />

    

    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group mb-3">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Price"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="CategoryId"></label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-control"></select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <!-- //update hinh anh moi -->
    <div class="form-group mb-3">
        <label>Image</label>
        <input type="file" name="imageUrl" class="form-control" />
    </div>

     <div class="mt-3">
        <h4>Image:</h4>
        <img src="@Model.ImageUrl" alt="Product Image" style="width: 100px; height: auto;" />
    </div>

    <div class="form-group mb-3">
        <label>Additional Images</label>
        <input type="file" name="imageUrls" multiple class="form-control" />
    </div>

<!-- hien thi anh -->
    <div class="mt-3">
        <h4>Additional Images:</h4>

        @foreach (var imageUrl in Model.ImageUrls)
        {
            <img src="@imageUrl" alt="Product Image" style="width: 100px; height: auto; margin: 5px;" />
        }
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
</form>

<br />

<a asp-action="Index">Back to List</a>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}